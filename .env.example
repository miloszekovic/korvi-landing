# Kopier denne filen til .env og fyll inn egne verdier
# cp .env.example .env

# Resend API-nøkkel — hent fra resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-postadressen som mottar kontaktforespørsler
CONTACT_EMAIL=milos.zekov@gmail.com

# Avsenderadresse.
# Under testing kan du bruke: Korvi <onboarding@resend.dev>
# Når korvi.no er verifisert i Resend: Korvi <noreply@korvi.no>
FROM_EMAIL=Korvi <onboarding@resend.dev>

# Serverport (valgfri, standard 3005)
PORT=3005
